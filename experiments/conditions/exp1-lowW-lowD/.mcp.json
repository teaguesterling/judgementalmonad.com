{
  "mcpServers": {
    "experiment": {
      "command": "python3",
      "args": [
        "../../tools/experiment-server/server.py",
        "--condition", "A",
        "--task-id", "${TASK_ID:-00}",
        "--log-dir", "../../logs",
        "--workspace", "${WORKSPACE:-.}",
        "--allowed-dirs", "${ALLOWED_DIRS}"
      ]
    }
  }
}
